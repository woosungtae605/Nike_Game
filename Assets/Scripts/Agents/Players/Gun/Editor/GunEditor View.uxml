<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="True">
    <ui:VisualElement name="GunVisualElement" style="flex-grow: 1;">
        <ui:DropdownField label="Class name" binding-path="className" name="Dropdown" />
        <uie:PropertyField name="GunDataField" binding-path="gunData" style="flex-grow: 1;" />
    </ui:VisualElement>
</ui:UXML>
